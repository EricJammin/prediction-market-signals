# Telegram Bot API credentials
# Create a bot via @BotFather and get a chat_id by messaging your bot
# then hitting https://api.telegram.org/bot<TOKEN>/getUpdates
TELEGRAM_BOT_TOKEN=your_bot_token_here
TELEGRAM_CHAT_ID=your_chat_id_here

# PizzINT monitor (optional — enables Telegram listener for DOUGHCON updates)
# Set PIZZINT_CHANNEL_ID to the channel/group chat ID where DOUGHCON updates appear.
# The bot identified by TELEGRAM_BOT_TOKEN must be a member of that chat.
# If unset, the monitor falls back to scraping pizzint.watch directly.
PIZZINT_CHANNEL_ID=
